# ============================================================
# DevLens AI — Environment Variables
# Copy this to .env and fill in your values. Never commit .env.
# ============================================================

# --- Application ---
APP_NAME="DevLens AI"
APP_VERSION="1.0.0"
DEBUG=false

# --- Security: API Key (used for X-API-Key header auth) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your-secret-api-key-here
SECRET_KEY=your-jwt-secret-key-here

# --- Database (PostgreSQL + pgvector) ---
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://devlens:devlens_password@localhost:5432/devlens

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- OpenAI (Embeddings + Chat) ---
# One API key powers both text-embedding-3-small and GPT-4o
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_CHAT_MODEL=gpt-4o        # Switch to gpt-4o-mini for lower cost

# --- GitHub OAuth (for private repo access) ---
# Create an OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# Optional: Personal Access Token for higher GitHub API rate limits (5000 req/hr)
# Leave empty to use unauthenticated (60 req/hr)
GITHUB_API_TOKEN=

# --- Frontend URL (used for OAuth redirect after GitHub login) ---
FRONTEND_URL=http://localhost:8081

# --- Ingestion Limits ---
MAX_REPO_SIZE_MB=500
MAX_FILE_COUNT=5000
MAX_FILE_SIZE_KB=500       # Skip individual files larger than this
INGESTION_TIMEOUT_SECONDS=300

# --- CORS Origins (comma-separated) ---
# Add your Cloudflare frontend URL here for production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_ANALYZE_PER_HOUR=10

# --- Cost Controls ---
# Cap total chunks embedded per ingestion (prevents runaway OpenAI spend)
# 10000 chunks ≈ $0.13 with text-embedding-3-small
OPENAI_MAX_CHUNKS_PER_INGESTION=10000
